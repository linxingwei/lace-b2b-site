# Public Cloudflare R2 custom domain, for example https://media.example.com
# Upload the files from public/products/ to the products/ prefix in your bucket.
NEXT_PUBLIC_R2_PUBLIC_URL=

# Optional inquiry delivery. Configure either a webhook, or all three Resend values.
INQUIRY_WEBHOOK_URL=
RESEND_API_KEY=
INQUIRY_TO_EMAIL=1650378792@qq.com
INQUIRY_FROM_EMAIL=

# Optional Google Search Console HTML verification token.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
