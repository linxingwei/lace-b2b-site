# Public Cloudflare R2 custom domain, for example https://media.example.com
# Upload the files from public/products/ to the products/ prefix in your bucket.
NEXT_PUBLIC_R2_PUBLIC_URL=

# Optional inquiry delivery. The Vercel Resend integration automatically provides
# RESEND_API_KEY and RESEND_EMAIL_DOMAIN. The two INQUIRY values are optional overrides.
INQUIRY_WEBHOOK_URL=
RESEND_API_KEY=
RESEND_EMAIL_DOMAIN=
INQUIRY_TO_EMAIL=1650378792@qq.com
INQUIRY_FROM_EMAIL=

# Optional Google Search Console HTML verification token.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
